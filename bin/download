#!/usr/bin/env bash

set -euo pipefail

current_script_path=${BASH_SOURCE[0]}
plugin_dir=$(dirname "$(dirname "$current_script_path")")

# shellcheck source=./lib/utils.bash
source "${plugin_dir}/lib/utils.bash"

mkdir -p "$ASDF_DOWNLOAD_PATH"

resolved_version="$(resolve_version "$ASDF_INSTALL_TYPE" "$ASDF_INSTALL_VERSION")"
[ -n "$resolved_version" ] || fail "Could not resolve $ASDF_INSTALL_VERSION to a Lisette release"

release_file="$ASDF_DOWNLOAD_PATH/$TOOL_NAME-$resolved_version.tar.gz"

rm -rf "${ASDF_DOWNLOAD_PATH:?}"/*

cleanup() {
	rm -rf "${ASDF_DOWNLOAD_PATH:?}"/*
}

trap cleanup ERR

download_release "$resolved_version" "$release_file"
tar -xzf "$release_file" -C "$ASDF_DOWNLOAD_PATH" --strip-components=1 || fail "Could not extract $release_file"
rm "$release_file"

trap - ERR
